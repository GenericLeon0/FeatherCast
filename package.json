{
  "name": "leancast",
  "version": "0.1.0",
  "description": "LeanCast – a lightweight Raycast-style app launcher for Windows (app search + global shortcut)",
  "author": "Kurt",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build": "vite build",
    "dist": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "vite": "^6.0.7"
  },
  "build": {
    "appId": "com.genericleon.leancast",
    "productName": "LeanCast",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/icon.ico",
      "build/tray.png"
    ],
    "icon": "build/icon.ico",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    }
  }
}
